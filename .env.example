# =============================================================================
# URLShortener — Environment Configuration
# =============================================================================
# URL shortener service for BAUER GROUP using Shlink.
#
# Short URLs: https://go.bauer-group.com/{shortcode}
# REST API:   https://go.bauer-group.com/rest/v3/...
# Admin UI:   https://ui.go.bauer-group.com
#
# Setup: cp .env.example .env && edit .env (fill in REQUIRED values)
# =============================================================================


# =============================================================================
# Stack Configuration
# =============================================================================

# Container name prefix (used for container names, volumes, networks)
STACK_NAME=url-shortener

# Container timezone
# Default: Etc/UTC
TIME_ZONE=Etc/UTC


# =============================================================================
# Image Versions
# =============================================================================

# Shlink server image tag
# https://hub.docker.com/r/shlinkio/shlink/tags
SHLINK_VERSION=stable

# Shlink web client image tag
# https://hub.docker.com/r/shlinkio/shlink-web-client/tags
SHLINK_WEB_VERSION=stable


# =============================================================================
# Shlink Server Configuration
# =============================================================================

# Domain for short URLs (REQUIRED — must match DNS)
SHLINK_DOMAIN=go.bauer-group.com

# HTTPS enabled (set to false for direct/development mode)
# Default: true
SHLINK_IS_HTTPS=true

# API key for REST API and web client authentication (REQUIRED)
# Generate: uuidgen or openssl rand -base64 32
SHLINK_API_KEY=

# PHP memory limit (optimiert für ≤5k Links)
# Default: 256M
SHLINK_MEMORY_LIMIT=256M


# =============================================================================
# RoadRunner Worker Configuration
# =============================================================================
# Shlink uses RoadRunner as its application server with long-running PHP workers.
# Each HTTP worker holds a PERSISTENT database connection for its entire lifetime.
# Task workers open/close connections per task but still occupy a slot when active.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ WORKER → DB CONNECTION ARCHITEKTUR                                         │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │                                                                             │
# │  RoadRunner ──┬── HTTP Worker 1  ──► persistent DB conn (open for lifetime)│
# │               ├── HTTP Worker 2  ──► persistent DB conn                    │
# │               ├── ...            ──► ...                                   │
# │               ├── HTTP Worker N  ──► persistent DB conn                    │
# │               ├── Task Worker 1  ──► DB conn (open/close per task)         │
# │               └── Task Worker M  ──► DB conn (open/close per task)         │
# │                                                                             │
# │  ⚠ Default (0) = Anzahl CPU-Kerne → auf großen Servern zu viele Worker!   │
# │                                                                             │
# │  Formel: POSTGRES_MAX_CONNECTIONS ≥ WEB + TASK + 4                         │
# │          (3 PG reserved + 1 Healthcheck)                                   │
# │                                                                             │
# ├───────────────────┬──────────┬──────────┬──────────────────────────────────┤
# │ Server-CPUs       │ WEB      │ TASK     │ Min. POSTGRES_MAX_CONNECTIONS    │
# ├───────────────────┼──────────┼──────────┼──────────────────────────────────┤
# │ 2 Kerne           │ 2        │ 1        │ 7                                │
# │ 4 Kerne           │ 4        │ 2        │ 10                               │
# │ 8 Kerne           │ 4        │ 2        │ 10                               │
# │ 16 Kerne          │ 8        │ 4        │ 16                               │
# │ 0 (auto = CPUs)   │ CPUs     │ CPUs     │ 2×CPUs + 4                       │
# └───────────────────┴──────────┴──────────┴──────────────────────────────────┘

# Number of HTTP workers (handles short URL redirects + API requests)
# 0 = auto-detect (CPU count) — NOT recommended, can exhaust DB connections
# Default: 4
WEB_WORKER_NUM=4

# Number of task workers (handles async jobs: visit tracking, GeoIP, notifications)
# 0 = auto-detect (CPU count) — NOT recommended
# Default: 2
TASK_WORKER_NUM=2


# =============================================================================
# Redirect Configuration
# =============================================================================
# Where to redirect when no short URL matches.
# Supports {DOMAIN} and {ORIGINAL_PATH} placeholders (Shlink v2.9+).

# Redirect when visiting the root domain (go.bauer-group.com/)
SHLINK_BASE_URL_REDIRECT=https://bauer-group.com/

# Redirect when short code doesn't exist or is disabled
SHLINK_INVALID_URL_REDIRECT=https://bauer-group.com/

# Redirect for any other unmatched path
SHLINK_404_REDIRECT=https://bauer-group.com/

# HTTP redirect status code (302 = temporary, 301 = permanent)
# Default: 302
SHLINK_REDIRECT_STATUS=302


# =============================================================================
# Short URL Settings
# =============================================================================

# Default length of generated short codes (minimum: 4)
# Default: 5
SHLINK_SHORT_CODE_LENGTH=5

# URL matching mode: "loosely" (ignore protocol/query) or "strict"
# Default: loosely
SHLINK_URL_MODE=loosely

# Automatically fetch page titles for short URLs
# Default: true
SHLINK_AUTO_RESOLVE_TITLES=true

# Anonymize visitor IP addresses (GDPR compliance)
# Default: true
SHLINK_ANONYMIZE_REMOTE_ADDR=true


# =============================================================================
# QR Code Defaults (optional)
# =============================================================================

# Default QR code size in pixels
# Default: 300
SHLINK_QR_SIZE=300

# QR code format: png or svg
# Default: png
SHLINK_QR_FORMAT=png

# QR code margin in pixels
# Default: 0
SHLINK_QR_MARGIN=0

# QR code error correction level: L, M, Q, H
# Default: L
SHLINK_QR_ERROR_CORRECTION=M


# =============================================================================
# GeoIP (optional)
# =============================================================================
# MaxMind GeoLite2 license key for IP geolocation.
# Register at: https://www.maxmind.com/en/geolite2/signup
# Leave empty to disable geolocation features.

SHLINK_GEOLITE_KEY=


# =============================================================================
# Web Client Configuration
# =============================================================================

# Subdomain for the admin web UI (requires DNS record)
# Default: ui.go.bauer-group.com
SHLINK_WEB_DOMAIN=ui.go.bauer-group.com

# Display name for the Shlink server in the web UI
SHLINK_SERVER_NAME=BAUER GROUP


# =============================================================================
# PostgreSQL Configuration
# =============================================================================
# Optimiert für ≤5.000 Links bei ~100.000 Visits/Monat (low RAM footprint).
# Visits sind Cold Data (Analytics) und werden nicht im RAM gehalten.

# Database name
# Default: shlink
POSTGRES_DB=shlink

# Database user
# Default: shlink
POSTGRES_USER=shlink

# Database password (REQUIRED)
# Generate: openssl rand -hex 32
POSTGRES_PASSWORD=

# PostgreSQL version (optional, default: 18)
# POSTGRES_VERSION=18

# -----------------------------------------------------------------------------
# Connection Settings
# -----------------------------------------------------------------------------
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ VERBINDUNGS-ARCHITEKTUR                                                     │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │                                                                             │
# │  RoadRunner Worker ──► Doctrine/PDO ──► PostgreSQL                         │
# │  (long-running)        (non-persistent)  (POSTGRES_MAX_CONNECTIONS)        │
# │                                                                             │
# │  Jeder RoadRunner HTTP-Worker hält eine DB-Connection dauerhaft offen.     │
# │  Task-Worker öffnen/schließen pro Task, belegen aber bei gleichzeitiger    │
# │  Ausführung ebenfalls einen Connection-Slot.                               │
# │                                                                             │
# │  ⚠ POSTGRES_MAX_CONNECTIONS muss ≥ WEB_WORKER_NUM + TASK_WORKER_NUM + 4   │
# │    sein (3 PG reserved + 1 Healthcheck). Sonst: "too many clients" error.  │
# │                                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘

# Maximum database connections
# Formula: ≥ WEB_WORKER_NUM + TASK_WORKER_NUM + 4
# Default: 64 (safe even with auto-detect workers on large servers)
POSTGRES_MAX_CONNECTIONS=64

# -----------------------------------------------------------------------------
# PostgreSQL Performance Tuning
# -----------------------------------------------------------------------------
# Alle Werte haben sinnvolle Defaults im Compose-File.
# Nur bei Bedarf anpassen und auskommentieren.
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DIMENSIONIERUNG                                                             │
# ├─────────────────────────────────────────────────────────────────────────────┤
# │                                                                             │
# │  Hot Path (Redirect):   short_urls + Indexes → immer im shared_buffers     │
# │  Cold Path (Analytics): visits-Tabelle → nicht RAM-relevant                 │
# │                                                                             │
# │  5.000 Links ≈ 13 MB Hot Data (Links + Indexes + PG Catalog)               │
# │  → Passt 10× in 128 MB shared_buffers                                      │
# │                                                                             │
# │  Visits (100k/Monat) werden einmal geschrieben und selten gelesen.          │
# │  PostgreSQL verdrängt Cold Pages automatisch (Clock-Sweep Eviction).        │
# │  Scaling-Faktor ist der Traffic (Visits/Monat), nicht die Linkzahl.         │
# │                                                                             │
# └─────────────────────────────────────────────────────────────────────────────┘
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ STORAGE I/O SETTINGS                                                        │
# │ (PostgreSQL: random_page_cost, effective_io_concurrency)                    │
# ├─────────────────────────────────┬───────────────────────────────────────────┤
# │ ENV Variable                    │ SSD/NVMe    │ HDD 10k    │ HDD 7.2k      │
# │                                 │ (default)   │ RPM        │ RPM           │
# ├─────────────────────────────────┼─────────────┼────────────┼───────────────┤
# │ PG_RANDOM_PAGE_COST             │ 1.1         │ 2.0        │ 4.0           │
# │ PG_EFFECTIVE_IO_CONCURRENCY     │ 200         │ 4          │ 2             │
# └─────────────────────────────────┴─────────────┴────────────┴───────────────┘
#
# PG_RANDOM_PAGE_COST=1.1
# PG_EFFECTIVE_IO_CONCURRENCY=200
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ MEMORY SETTINGS                                                             │
# │ (PostgreSQL: shared_buffers, effective_cache_size, work_mem,                │
# │              maintenance_work_mem)                                          │
# │                                                                             │
# │ Hinweis: effective_cache_size ist ein Planner-Hint (kein RAM-Verbrauch).    │
# │ Er teilt PostgreSQL mit, wie viel OS Page Cache verfügbar ist.              │
# ├─────────────────────────────────┬───────────┬───────────┬───────────────────┤
# │ ENV Variable                    │ Standard  │ Mittel    │ Produktion        │
# │                                 │ (default) │           │                   │
# │                                 │ ≤5k Links │ ≤50k Links│ >50k Links        │
# │                                 │ ≤100k     │ ≤500k     │ >1M               │
# │                                 │ Visits/Mo │ Visits/Mo │ Visits/Mo         │
# ├─────────────────────────────────┼───────────┼───────────┼───────────────────┤
# │ PG_SHARED_BUFFERS               │ 128MB     │ 256MB     │ 512MB            │
# │ PG_EFFECTIVE_CACHE_SIZE         │ 256MB     │ 512MB     │ 1GB              │
# │ PG_WORK_MEM                     │ 2MB       │ 4MB       │ 8MB              │
# │ PG_MAINTENANCE_WORK_MEM         │ 32MB      │ 64MB      │ 128MB            │
# └─────────────────────────────────┴───────────┴───────────┴───────────────────┘
#
# PG_SHARED_BUFFERS=128MB
# PG_EFFECTIVE_CACHE_SIZE=256MB
# PG_WORK_MEM=2MB
# PG_MAINTENANCE_WORK_MEM=32MB
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ WAL SETTINGS (Write-Ahead Log)                                              │
# │ (PostgreSQL: max_wal_size, min_wal_size)                                    │
# ├─────────────────────────────────┬───────────┬───────────┬───────────────────┤
# │ ENV Variable                    │ Standard  │ Mittel    │ Produktion        │
# │                                 │ (default) │           │                   │
# ├─────────────────────────────────┼───────────┼───────────┼───────────────────┤
# │ PG_MAX_WAL_SIZE                 │ 128MB     │ 256MB     │ 512MB            │
# │ PG_MIN_WAL_SIZE                 │ 32MB      │ 64MB      │ 128MB            │
# └─────────────────────────────────┴───────────┴───────────┴───────────────────┘
#
# PG_MAX_WAL_SIZE=128MB
# PG_MIN_WAL_SIZE=32MB
#
# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ RAM FOOTPRINT (PostgreSQL-Prozess, realistisch)                             │
# ├─────────────────────────┬───────────┬───────────┬───────────────────────────┤
# │ Szenario                │ Standard  │ Mittel    │ Produktion                │
# ├─────────────────────────┼───────────┼───────────┼───────────────────────────┤
# │ Idle                    │ ~150 MB   │ ~280 MB   │ ~400 MB                   │
# │ Typisch (3–5 conn)      │ ~175 MB   │ ~320 MB   │ ~450 MB                   │
# │ Peak (max connections)  │ ~280 MB   │ ~540 MB   │ ~700 MB                   │
# └─────────────────────────┴───────────┴───────────┴───────────────────────────┘


# =============================================================================
# Traefik Configuration (docker-compose.traefik.yml)
# =============================================================================
# DNS record must resolve to ${SHLINK_DOMAIN} before starting.

# External Traefik network name (must already exist)
PROXY_NETWORK=EDGEPROXY


# =============================================================================
# Port Settings (docker-compose.development.yml)
# =============================================================================
# Direct port binding when NOT using Traefik reverse proxy.

# Shlink server port (API + short URL resolution)
EXPOSED_SERVER_PORT=8080

# Web client port (admin UI)
EXPOSED_WEB_PORT=8081


# =============================================================================
# Deployment
# =============================================================================
#
# Production + Traefik (HTTPS):
#   docker compose -f docker-compose.traefik.yml up -d
#   Short URLs: https://go.bauer-group.com/{shortcode}
#   REST API:   https://go.bauer-group.com/rest/v3/...
#   Admin UI:   https://ui.go.bauer-group.com
#
# Production + Coolify:
#   Deploy via Coolify UI with docker-compose.coolify.yml
#   Set environment variables in Coolify dashboard
#
# Testing (direct port access):
#   docker compose -f docker-compose.development.yml up -d
#   Shlink API: http://localhost:8080
#   Admin UI:   http://localhost:8081
#
# Documentation:
#   https://shlink.io/documentation/
#   https://shlink.io/documentation/environment-variables/
#   https://shlink.io/documentation/advanced/special-redirects/
#
