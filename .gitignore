# Environment (Secrets)
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
.claude/
*.code-workspace
.history/

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Logs
*.log
logs/

# Python
__pycache__/
*.pyc
*.pyo

# Temporary Files
*.tmp
*.temp
*.bak
*~
